# Dependencias (se instalan dentro de la imagen)
/vendor
/node_modules

# Assets compilados localmente (se regeneran en el stage de Node)
/public/build
/public/storage
/public/hot

# Entorno y secretos
.env
.env.*
!.env.example

# Base de datos local
/database/*.sqlite
/database/*.sqlite-*

# Caché y logs de Laravel (se regeneran en runtime, evita arrastrar dev providers)
/bootstrap/cache/*.php
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*

# Control de versiones y herramientas
/.git
/.github
/.idea
/.vscode
/tests
/.phpunit.result.cache
npm-debug.log
yarn-error.log
